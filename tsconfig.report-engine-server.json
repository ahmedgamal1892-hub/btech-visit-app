{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "ignoreDeprecations": "6.0",
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.report-engine-server.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023"],
    "types": ["node", "vite/client"],
    "skipLibCheck": true,
    "jsx": "react-jsx",

    /* Bundler mode — matches Vite SSR loading of server modules */
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src/report-engine/server"]
}
